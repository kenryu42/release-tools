{
  "name": "release-tools",
  "version": "0.1.0",
  "description": "Shared publish, changelog, and homebrew utilities for release automation.",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "J Liew",
    "email": "jliew@420024lab.com"
  },
  "bin": {
    "release-tools": "./src/cli/index.ts"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "knip": "knip-bun",
    "lint": "biome check --write .",
    "lint:ci": "biome ci .",
    "check": "bun run typecheck && bun run knip && bun run lint && AGENT=1 bun test --coverage",
    "release-tools": "bun run src/cli/index.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "knip": "^6.0.1",
    "lint-staged": "^16.4.0",
    "typescript": "^5"
  },
  "knip": {
    "ignoreDependencies": [
      "lint-staged"
    ]
  },
  "lint-staged": {
    "*": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "exports": {
    "./config": "./src/cli/config.ts"
  },
  "private": true
}
